{
  "manifest_version": 3,
  "name": "SafeUpload Shield",
  "version": "1.0",
  "description": "Protect your identity by cloaking your photos before uploading them.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "SafeUpload"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:7860/*",
    "http://localhost:7860/*"
  ]
}
